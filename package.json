{
    "name": "django-prosemirror",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -b && vite build",
        "build:dev": "tsc -b && vite build --watch --mode=dev",
        "test": "vitest",
        "test:ci": "vitest --no-color --reporter=verbose --run --coverage",
        "test:coverage": "vitest --reporter=verbose --coverage",
        "type-check": "tsc --noEmit",
        "type-check:watch": "tsc --noEmit --watch",
        "lint": "eslint frontend/",
        "format": "prettier --write frontend/",
        "format:check": "prettier --check frontend/"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@preact/preset-vite": "^2.10.2",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/preact": "^3.2.4",
        "@vitest/coverage-v8": "^4.1.1",
        "eslint": "^10.2.0",
        "globals": "^16.0.0",
        "jsdom": "^26.1.0",
        "prettier": "^3.6.2",
        "sass-embedded": "^1.92.1",
        "typescript-eslint": "^8.58.2",
        "vite": "^7.3.2",
        "vitest": "^4.1.1"
    },
    "dependencies": {
        "@preact/signals": "^2.3.1",
        "clsx": "^2.1.1",
        "crelt": "^1.0.6",
        "microscope-sass": "^2.0.0",
        "preact": "^10.28.4",
        "prosemirror-example-setup": "^1.2.3",
        "prosemirror-menu": "^1.2.5",
        "prosemirror-model": "^1.25.3",
        "prosemirror-schema-basic": "^1.2.4",
        "prosemirror-schema-list": "^1.5.1",
        "prosemirror-state": "^1.4.3",
        "prosemirror-tables": "^1.7.1",
        "prosemirror-utils": "^1.2.2",
        "prosemirror-view": "^1.41.0"
    },
    "overrides": {
        "rollup": "^4.59.0",
        "immutable": "^5.1.5"
    },
    "optionalDependencies": {
        "@esbuild/linux-x64": "*",
        "@rollup/rollup-linux-x64-gnu": "*"
    }
}
